# Telegram token from BotFather. Never commit a real token.
TELEGRAM_BOT_TOKEN=put_telegram_token_here

# auto chooses Amvera when AMVERA_API_TOKEN is set, otherwise OpenAI-compatible
# when OPENAI_API_KEY is set, otherwise local retrieval-only fallback.
AI_PROVIDER=auto

# OpenAI-compatible provider settings.
# Free Gemini option:
# AI_PROVIDER=openai
# OPENAI_API_KEY=your_gemini_api_key
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Amvera direct API settings, based on the Habr article flow.
AMVERA_API_TOKEN=
AMVERA_API_URL=https://kong-proxy.yc.amvera.ru/api/v1/models/gpt
AMVERA_MODEL=gpt-5

# Retrieval and memory tuning.
TOP_K_CHUNKS=5
MAX_HISTORY_MESSAGES=8
